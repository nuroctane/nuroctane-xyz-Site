{
  "installCommand": "npx -y pnpm@10 install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/digital-sea/dist/public",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/github-contrib/refresh",
      "schedule": "0 12 * * *"
    }
  ]
}
